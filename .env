# Service port
PORT=18765

# Enable or disable the custom update feature
UPDATE_ENABLED=true

# NocoBase update list API URL, the app reads the first record after sorting by -id
UPDATE_METADATA_URL=https://wms-test.tamagawa-suzhou.com/api/t_print_version_update:list?sort%5B%5D=-id&appends%5B%5D=path&filter=%7B%22%24and%22%3A%5B%7B%22status%22%3A%7B%22%24eq%22%3A%22true%22%7D%7D%5D%7D

# Token used when requesting update metadata or downloading the installer
UPDATE_REQUEST_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOjEsInJvbGVOYW1lIjoicm9vdCIsImlhdCI6MTc3NDUxNDM5MSwiZXhwIjoxNzc3MTA2MzkxfQ.4bnZVVvuLump1tLRTIAFZMKx00TYnVHCqGBrgi38rmE

# Header name used to send the token, for example Authorization or X-Token
UPDATE_REQUEST_TOKEN_HEADER=Authorization

# Prefix added before the token value, for example "Bearer "
UPDATE_REQUEST_TOKEN_PREFIX=Bearer 

# Request timeout in milliseconds for metadata and download requests
UPDATE_REQUEST_TIMEOUT=15000

# Whether to automatically check for updates on app startup
UPDATE_AUTO_CHECK_ON_START=true

# Delay before the startup update check runs, in milliseconds
UPDATE_AUTO_CHECK_DELAY_MS=5000

# Subdirectory name under app userData for storing downloaded installers
UPDATE_DOWNLOAD_DIR_NAME=updates
