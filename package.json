{
  "name": "print-helper",
  "version": "1.0.0",
  "description": "Windows printing service with Socket.io communication - Electron based",
  "main": "src/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "node scripts/dev.js",
    "dev:renderer": "vite --config vite.renderer.config.js",
    "dev:electron": "electron .",
    "build:renderer": "vite build --config vite.renderer.config.js",
    "build": "npm run build:renderer && electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "print",
    "socket",
    "electron",
    "windows-service"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron-log": "^5.0.0",
    "node-printer": "^1.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.4.12"
  },
  "build": {
    "appId": "com.printhelper.app",
    "productName": "打印助手",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "scripts/**/*",
      "assets/**/*",
      "package.json",
      ".env"
    ],
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "打印助手"
    }
  }
}
