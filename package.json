{
  "name": "print-helper",
  "version": "1.0.0",
  "description": "Windows printing service with Socket.io communication - Electron based",
  "main": "src/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "keywords": ["print", "socket", "electron", "windows-service"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron-log": "^5.0.0",
    "node-printer": "^1.0.4",
    "socket.io": "^4.6.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.printhelper.app",
    "productName": "打印服务",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PrintHelper"
    }
  }
}
